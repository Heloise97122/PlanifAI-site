# Variables d'environnement pour la PRODUCTION (à définir sur Render).
# En local, ne rien mettre : l'app utilise automatiquement SQLite.

# Base de données PostgreSQL hébergée (ex. depuis Neon).
# Sans cette variable, l'app utilise un fichier SQLite local.
DATABASE_URL=postgresql://utilisateur:motdepasse@hote:5432/nom_base

# Clé secrète pour signer les sessions de connexion.
# Mettre une valeur aléatoire unique (ne jamais la partager).
SECRET_KEY=remplacez-par-une-valeur-aleatoire-unique
